[
  {
    "disease_id": "dengue",
    "disease_name_en": "Dengue Fever",
    "disease_name_bn": "ডেঙ্গু জ্বর",
    "category": "infectious",
    "specialty": "general_medicine",
    "question": "How long does dengue fever last?",
    "answer": "Acute illness typically lasts 5-7 days. Fever usually breaks on day 4-5, but this is also when severe complications can develop (critical phase). Full recovery may take 2-4 weeks with persistent fatigue. Monitor closely during the critical phase."
  },
  {
    "disease_id": "dengue",
    "disease_name_en": "Dengue Fever",
    "disease_name_bn": "ডেঙ্গু জ্বর",
    "category": "infectious",
    "specialty": "general_medicine",
    "question": "Can I take paracetamol for dengue?",
    "answer": "Yes, paracetamol (Napa, Ace) is safe and recommended for fever and pain in dengue. NEVER take aspirin, ibuprofen, or diclofenac — these increase bleeding risk which can be fatal in dengue. Maximum 4 grams paracetamol per day for adults."
  },
  {
    "disease_id": "dengue",
    "disease_name_en": "Dengue Fever",
    "disease_name_bn": "ডেঙ্গু জ্বর",
    "category": "infectious",
    "specialty": "general_medicine",
    "question": "When should I go to hospital for dengue?",
    "answer": "Go immediately if you have: severe abdominal pain, persistent vomiting, bleeding from gums or nose, blood in vomit or stool, extreme weakness, cold clammy skin, or decreased urination. These are warning signs of severe dengue requiring urgent hospital care."
  },
  {
    "disease_id": "dengue",
    "disease_name_en": "Dengue Fever",
    "disease_name_bn": "ডেঙ্গু জ্বর",
    "category": "infectious",
    "specialty": "general_medicine",
    "question": "Can dengue come back after recovery?",
    "answer": "Yes, you can get dengue again. There are 4 serotypes (DENV 1-4). Recovering from one gives lifelong immunity to that type only. A second infection with a different serotype actually increases risk of severe dengue. Continue prevention even after recovering."
  },
  {
    "disease_id": "dengue",
    "disease_name_en": "Dengue Fever",
    "disease_name_bn": "ডেঙ্গু জ্বর",
    "category": "infectious",
    "specialty": "general_medicine",
    "question": "What is the platelet count danger level in dengue?",
    "answer": "Normal platelets are 150,000-450,000. In dengue, platelets often drop. Below 100,000 needs close monitoring. Below 20,000 or with active bleeding may require platelet transfusion. Platelet count alone doesn't determine severity — clinical warning signs matter more."
  },
  {
    "disease_id": "dengue",
    "disease_name_en": "Dengue Fever",
    "disease_name_bn": "ডেঙ্গু জ্বর",
    "category": "infectious",
    "specialty": "general_medicine",
    "question": "Can pregnant women get dengue?",
    "answer": "Yes, and it can be more severe. Risks include miscarriage, preterm birth, low birth weight, and vertical transmission to baby. Pregnant women with fever in Bangladesh should be tested for dengue immediately and monitored in hospital."
  },
  {
    "disease_id": "dengue",
    "disease_name_en": "Dengue Fever",
    "disease_name_bn": "ডেঙ্গু জ্বর",
    "category": "infectious",
    "specialty": "general_medicine",
    "question": "How is dengue diagnosed?",
    "answer": "Blood tests: NS1 antigen (positive days 1-5), IgM antibody (positive after day 4-5), and CBC for platelet/hematocrit. Most diagnostic centers in Dhaka do this same-day for 800-1500 BDT."
  },
  {
    "disease_id": "dengue",
    "disease_name_en": "Dengue Fever",
    "disease_name_bn": "ডেঙ্গু জ্বর",
    "category": "infectious",
    "specialty": "general_medicine",
    "question": "Are home remedies like papaya leaf juice effective for dengue?",
    "answer": "Some small studies suggest papaya leaf extract may modestly increase platelet count, but it's not a substitute for medical care. Don't rely on home remedies — monitor warning signs and seek hospital care when indicated. Hydration is the most important home measure."
  },
  {
    "disease_id": "dengue",
    "disease_name_en": "Dengue Fever",
    "disease_name_bn": "ডেঙ্গু জ্বর",
    "category": "infectious",
    "specialty": "general_medicine",
    "question": "Can I get dengue twice in one season?",
    "answer": "Yes, possibly — if exposed to a different serotype. Second infections are typically more severe. This is why prevention remains critical even after recovery."
  },
  {
    "disease_id": "dengue",
    "disease_name_en": "Dengue Fever",
    "disease_name_bn": "ডেঙ্গু জ্বর",
    "category": "infectious",
    "specialty": "general_medicine",
    "question": "What food should I eat during dengue?",
    "answer": "Focus on hydration: ORS, coconut water, fresh fruit juice, soups. Easy-to-digest foods like khichuri, daal, banana, papaya. Avoid oily and spicy food. Eat small frequent meals if nausea is present. Coconut water and ORS help with fluid balance."
  },
  {
    "disease_id": "typhoid",
    "disease_name_en": "Typhoid Fever",
    "disease_name_bn": "টাইফয়েড জ্বর",
    "category": "infectious",
    "specialty": "general_medicine",
    "question": "How is typhoid different from regular fever?",
    "answer": "Typhoid causes a sustained, stepwise rising fever lasting weeks (not days), often with relative bradycardia (slow pulse despite high fever), abdominal symptoms, and rose spots. Regular viral fever resolves in 3-7 days. Blood culture confirms typhoid."
  },
  {
    "disease_id": "typhoid",
    "disease_name_en": "Typhoid Fever",
    "disease_name_bn": "টাইফয়েড জ্বর",
    "category": "infectious",
    "specialty": "general_medicine",
    "question": "Is the Widal test reliable for typhoid?",
    "answer": "Widal test is unreliable — many false positives and negatives. Blood culture is the gold standard and should be done in the first week of fever. In Bangladesh, request blood culture along with or instead of Widal."
  },
  {
    "disease_id": "typhoid",
    "disease_name_en": "Typhoid Fever",
    "disease_name_bn": "টাইফয়েড জ্বর",
    "category": "infectious",
    "specialty": "general_medicine",
    "question": "How long does typhoid treatment take?",
    "answer": "Antibiotic course is typically 7-14 days. Fever often takes 3-5 days to come down after starting antibiotics. Complete the full course even if you feel better, otherwise relapse and resistance can develop."
  },
  {
    "disease_id": "typhoid",
    "disease_name_en": "Typhoid Fever",
    "disease_name_bn": "টাইফয়েড জ্বর",
    "category": "infectious",
    "specialty": "general_medicine",
    "question": "Can I die from typhoid?",
    "answer": "Yes, untreated typhoid has 10-20% mortality. With proper antibiotics, mortality is less than 1%. Complications like intestinal perforation can be fatal. Seek treatment early."
  },
  {
    "disease_id": "typhoid",
    "disease_name_en": "Typhoid Fever",
    "disease_name_bn": "টাইফয়েড জ্বর",
    "category": "infectious",
    "specialty": "general_medicine",
    "question": "Why is XDR typhoid a concern?",
    "answer": "Extensively Drug-Resistant typhoid doesn't respond to most common antibiotics including ciprofloxacin and cefixime. Only a few drugs work (azithromycin, meropenem). It's spreading in South Asia. Always do culture and sensitivity in suspected typhoid."
  },
  {
    "disease_id": "typhoid",
    "disease_name_en": "Typhoid Fever",
    "disease_name_bn": "টাইফয়েড জ্বর",
    "category": "infectious",
    "specialty": "general_medicine",
    "question": "Should my family members get tested if I have typhoid?",
    "answer": "If they have symptoms, yes. Asymptomatic family members generally don't need testing but should follow good hygiene (handwashing, separate utensils). Up to 5% of recovered patients become chronic carriers — those handling food should be tested."
  },
  {
    "disease_id": "typhoid",
    "disease_name_en": "Typhoid Fever",
    "disease_name_bn": "টাইফয়েড জ্বর",
    "category": "infectious",
    "specialty": "general_medicine",
    "question": "Is typhoid vaccine effective?",
    "answer": "Yes — Typbar TCV (conjugate vaccine) gives ~80% protection lasting 5+ years. Recommended for all children in endemic areas. Available at most private clinics in Bangladesh for 1500-2500 BDT."
  },
  {
    "disease_id": "typhoid",
    "disease_name_en": "Typhoid Fever",
    "disease_name_bn": "টাইফয়েড জ্বর",
    "category": "infectious",
    "specialty": "general_medicine",
    "question": "Can I eat regular food during typhoid?",
    "answer": "Eat soft, easily digestible food: khichuri, rice with daal, mashed potato, banana, yogurt. Avoid spicy, oily, and fibrous foods that stress the gut. Stay well hydrated."
  },
  {
    "disease_id": "typhoid",
    "disease_name_en": "Typhoid Fever",
    "disease_name_bn": "টাইফয়েড জ্বর",
    "category": "infectious",
    "specialty": "general_medicine",
    "question": "How long am I contagious with typhoid?",
    "answer": "You can shed bacteria in stool for weeks even after symptoms resolve. Practice strict handwashing. 2-5% become chronic carriers shedding bacteria for years. Stool culture 1 month after recovery can confirm clearance."
  },
  {
    "disease_id": "typhoid",
    "disease_name_en": "Typhoid Fever",
    "disease_name_bn": "টাইফয়েড জ্বর",
    "category": "infectious",
    "specialty": "general_medicine",
    "question": "Can typhoid recur?",
    "answer": "Yes — relapse in 5-15% of cases, usually 1-3 weeks after treatment ends. Often due to incomplete treatment. If fever returns, see a doctor immediately and repeat blood culture."
  },
  {
    "disease_id": "malaria",
    "disease_name_en": "Malaria",
    "disease_name_bn": "ম্যালেরিয়া",
    "category": "infectious",
    "specialty": "general_medicine",
    "question": "What's the difference between dengue and malaria fever?",
    "answer": "Dengue fever is continuous (24/7 high) with body aches and possible rash; malaria fever is cyclical (chills then high fever then sweating, every 24-48 hours). Diagnosis confirmed by blood tests — NS1/IgM for dengue, peripheral blood smear or RDT for malaria."
  },
  {
    "disease_id": "malaria",
    "disease_name_en": "Malaria",
    "disease_name_bn": "ম্যালেরিয়া",
    "category": "infectious",
    "specialty": "general_medicine",
    "question": "How is malaria diagnosed?",
    "answer": "Blood smear (microscopy) or Rapid Diagnostic Test (RDT). Available at upazila health complexes and major labs. Results in 30 minutes for RDT."
  },
  {
    "disease_id": "malaria",
    "disease_name_en": "Malaria",
    "disease_name_bn": "ম্যালেরিয়া",
    "category": "infectious",
    "specialty": "general_medicine",
    "question": "Can malaria be cured completely?",
    "answer": "Yes, with proper treatment. P. vivax can have dormant liver stages that cause relapses — need primaquine (after G6PD testing) to prevent relapse. P. falciparum doesn't relapse but needs prompt treatment to prevent severe disease."
  },
  {
    "disease_id": "malaria",
    "disease_name_en": "Malaria",
    "disease_name_bn": "ম্যালেরিয়া",
    "category": "infectious",
    "specialty": "general_medicine",
    "question": "Is malaria common in Dhaka?",
    "answer": "No, Dhaka has very low malaria transmission. Most cases come from travel to hill districts. Fever in Dhaka residents is much more likely dengue, typhoid, or viral infection."
  },
  {
    "disease_id": "malaria",
    "disease_name_en": "Malaria",
    "disease_name_bn": "ম্যালেরিয়া",
    "category": "infectious",
    "specialty": "general_medicine",
    "question": "Can pregnant women take malaria treatment?",
    "answer": "Yes, but drug selection matters. Quinine and clindamycin are safe in first trimester; ACTs can be used in 2nd and 3rd trimesters. Always under medical supervision. Pregnant women with malaria need hospitalization."
  },
  {
    "disease_id": "malaria",
    "disease_name_en": "Malaria",
    "disease_name_bn": "ম্যালেরিয়া",
    "category": "infectious",
    "specialty": "general_medicine",
    "question": "What is cerebral malaria?",
    "answer": "Severe complication of P. falciparum where parasites obstruct brain blood vessels. Symptoms: confusion, seizures, coma. Mortality 15-20% even with treatment. Medical emergency requiring IV artesunate."
  },
  {
    "disease_id": "malaria",
    "disease_name_en": "Malaria",
    "disease_name_bn": "ম্যালেরিয়া",
    "category": "infectious",
    "specialty": "general_medicine",
    "question": "How can I protect myself when visiting Bandarban?",
    "answer": "Use insecticide-treated bed nets, wear long sleeves at dawn/dusk, apply DEET repellent, consider doxycycline prophylaxis (consult doctor 1 week before travel). Seek care immediately if fever develops within a month of return."
  },
  {
    "disease_id": "malaria",
    "disease_name_en": "Malaria",
    "disease_name_bn": "ম্যালেরিয়া",
    "category": "infectious",
    "specialty": "general_medicine",
    "question": "Can malaria be transmitted from person to person?",
    "answer": "Not through normal contact. Transmission requires mosquito bite. Rare transmission can occur via blood transfusion, sharing needles, or mother-to-baby during pregnancy/birth."
  },
  {
    "disease_id": "malaria",
    "disease_name_en": "Malaria",
    "disease_name_bn": "ম্যালেরিয়া",
    "category": "infectious",
    "specialty": "general_medicine",
    "question": "How long after a mosquito bite do malaria symptoms start?",
    "answer": "Typically 10-15 days for P. falciparum, 12-18 days for P. vivax. Can be longer (up to several months) with vivax due to dormant liver stages. Tell your doctor about any travel history."
  },
  {
    "disease_id": "malaria",
    "disease_name_en": "Malaria",
    "disease_name_bn": "ম্যালেরিয়া",
    "category": "infectious",
    "specialty": "general_medicine",
    "question": "Is there a malaria vaccine?",
    "answer": "RTS,S/AS01 (Mosquirix) is approved for children in high-transmission African countries. Not currently part of Bangladesh's vaccine program. Prevention still relies on bed nets and vector control."
  },
  {
    "disease_id": "hepatitis_b",
    "disease_name_en": "Hepatitis B",
    "disease_name_bn": "হেপাটাইটিস বি",
    "category": "infectious",
    "specialty": "gastroenterology",
    "question": "How can I get tested for Hepatitis B?",
    "answer": "Simple blood test — HBsAg (Hepatitis B surface antigen). Available at any diagnostic lab in Bangladesh for 200-500 BDT. If positive, additional tests (HBeAg, HBV DNA, liver function) determine treatment need."
  },
  {
    "disease_id": "hepatitis_b",
    "disease_name_en": "Hepatitis B",
    "disease_name_bn": "হেপাটাইটিস বি",
    "category": "infectious",
    "specialty": "gastroenterology",
    "question": "If I have Hepatitis B, will my baby get it?",
    "answer": "Risk of transmission to baby is high (up to 90% if mother is HBeAg positive). However, giving the baby Hepatitis B vaccine + immunoglobulin (HBIG) within 12 hours of birth prevents transmission in 95% of cases. Inform your doctor before delivery."
  },
  {
    "disease_id": "hepatitis_b",
    "disease_name_en": "Hepatitis B",
    "disease_name_bn": "হেপাটাইটিস বি",
    "category": "infectious",
    "specialty": "gastroenterology",
    "question": "Can Hepatitis B be cured?",
    "answer": "Chronic HBV is rarely 'cured' but can be effectively controlled with antiviral medications taken long-term (often lifelong). Treatment reduces liver damage and cancer risk significantly. Acute hepatitis B in adults usually clears spontaneously in 90-95% of cases."
  },
  {
    "disease_id": "hepatitis_b",
    "disease_name_en": "Hepatitis B",
    "disease_name_bn": "হেপাটাইটিস বি",
    "category": "infectious",
    "specialty": "gastroenterology",
    "question": "How is Hepatitis B different from Hepatitis C?",
    "answer": "Both attack the liver. HBV is a DNA virus, transmitted through blood, sex, and birth. HCV is RNA, mainly through blood. HBV has a vaccine; HCV doesn't but is curable with newer drugs (DAAs). Both can cause cirrhosis and cancer."
  },
  {
    "disease_id": "hepatitis_b",
    "disease_name_en": "Hepatitis B",
    "disease_name_bn": "হেপাটাইটিস বি",
    "category": "infectious",
    "specialty": "gastroenterology",
    "question": "Is Hepatitis B vaccine safe in pregnancy?",
    "answer": "Yes, it's safe and recommended if needed during pregnancy. The vaccine contains no live virus."
  },
  {
    "disease_id": "hepatitis_b",
    "disease_name_en": "Hepatitis B",
    "disease_name_bn": "হেপাটাইটিস বি",
    "category": "infectious",
    "specialty": "gastroenterology",
    "question": "Can I have sex if I have Hepatitis B?",
    "answer": "Yes, but use condoms to prevent transmission. Your partner should be tested and vaccinated. Once vaccinated and immune (anti-HBs >10 IU/L), they're protected."
  },
  {
    "disease_id": "hepatitis_b",
    "disease_name_en": "Hepatitis B",
    "disease_name_bn": "হেপাটাইটিস বি",
    "category": "infectious",
    "specialty": "gastroenterology",
    "question": "How long can Hepatitis B virus survive outside the body?",
    "answer": "Up to 7 days on surfaces. This is why sharing razors, toothbrushes, and nail clippers with infected persons is risky. Wash blood spills with diluted bleach (1:10)."
  },
  {
    "disease_id": "hepatitis_b",
    "disease_name_en": "Hepatitis B",
    "disease_name_bn": "হেপাটাইটিস বি",
    "category": "infectious",
    "specialty": "gastroenterology",
    "question": "What should I avoid if I have Hepatitis B?",
    "answer": "Alcohol (severely worsens liver damage), unprescribed medications/supplements (many are liver-toxic), and raw shellfish (risk of additional infections). Maintain healthy weight to prevent fatty liver."
  },
  {
    "disease_id": "hepatitis_b",
    "disease_name_en": "Hepatitis B",
    "disease_name_bn": "হেপাটাইটিস বি",
    "category": "infectious",
    "specialty": "gastroenterology",
    "question": "Should my whole family get tested?",
    "answer": "Yes, household contacts and sexual partners should be tested for HBsAg, anti-HBc, and anti-HBs. Negative contacts should be vaccinated. Especially important for children of infected mothers."
  },
  {
    "disease_id": "hepatitis_b",
    "disease_name_en": "Hepatitis B",
    "disease_name_bn": "হেপাটাইটিস বি",
    "category": "infectious",
    "specialty": "gastroenterology",
    "question": "Can I work and live normally with Hepatitis B?",
    "answer": "Yes. Hepatitis B doesn't spread through casual contact, sharing food/utensils, hugging, or coughing. You can attend school, work, and participate in all activities. Just avoid sharing blood-contact items."
  },
  {
    "disease_id": "tuberculosis",
    "disease_name_en": "Tuberculosis (TB)",
    "disease_name_bn": "যক্ষ্মা",
    "category": "infectious",
    "specialty": "pulmonology",
    "question": "How is TB diagnosed?",
    "answer": "Sputum tests: AFB smear (microscopy), GeneXpert MTB/RIF (detects TB + rifampicin resistance in 2 hours), culture. Chest X-ray supports diagnosis. GeneXpert is free at upazila health complexes."
  },
  {
    "disease_id": "tuberculosis",
    "disease_name_en": "Tuberculosis (TB)",
    "disease_name_bn": "যক্ষ্মা",
    "category": "infectious",
    "specialty": "pulmonology",
    "question": "Is TB treatment really free in Bangladesh?",
    "answer": "Yes, all TB testing and medications are completely free at any government DOTS center, BRAC TB centers, and Damien Foundation clinics. Don't buy private — government drugs are quality-assured and free."
  },
  {
    "disease_id": "tuberculosis",
    "disease_name_en": "Tuberculosis (TB)",
    "disease_name_bn": "যক্ষ্মা",
    "category": "infectious",
    "specialty": "pulmonology",
    "question": "Will I be contagious during TB treatment?",
    "answer": "Most patients become non-contagious within 2-3 weeks of starting effective treatment. Sputum tests confirm. Wear a mask and stay home for the first 2 weeks. Family members should be screened."
  },
  {
    "disease_id": "tuberculosis",
    "disease_name_en": "Tuberculosis (TB)",
    "disease_name_bn": "যক্ষ্মা",
    "category": "infectious",
    "specialty": "pulmonology",
    "question": "Can TB be cured?",
    "answer": "Yes, drug-sensitive TB is cured in >95% of cases with 6 months of treatment. The key is completing the full course — stopping early causes drug resistance and relapse."
  },
  {
    "disease_id": "tuberculosis",
    "disease_name_en": "Tuberculosis (TB)",
    "disease_name_bn": "যক্ষ্মা",
    "category": "infectious",
    "specialty": "pulmonology",
    "question": "What is MDR-TB?",
    "answer": "Multi-Drug-Resistant TB doesn't respond to isoniazid and rifampicin (the two strongest first-line drugs). Requires 9-20 months of treatment with more toxic drugs. Often caused by incomplete previous treatment. Diagnosed by GeneXpert."
  },
  {
    "disease_id": "tuberculosis",
    "disease_name_en": "Tuberculosis (TB)",
    "disease_name_bn": "যক্ষ্মা",
    "category": "infectious",
    "specialty": "pulmonology",
    "question": "Can TB affect organs other than lungs?",
    "answer": "Yes — extra-pulmonary TB can affect lymph nodes, bones (spine — Pott's disease), brain (TB meningitis), kidneys, intestines, skin. Symptoms vary by site. Lymph node TB is the most common extra-pulmonary form in Bangladesh."
  },
  {
    "disease_id": "tuberculosis",
    "disease_name_en": "Tuberculosis (TB)",
    "disease_name_bn": "যক্ষ্মা",
    "category": "infectious",
    "specialty": "pulmonology",
    "question": "Do I need special diet during TB treatment?",
    "answer": "Eat protein-rich and calorie-dense food: eggs, fish, milk, meat, daal, nuts. Many TB patients are underweight; weight gain is a good sign. Avoid alcohol (interacts with TB drugs)."
  },
  {
    "disease_id": "tuberculosis",
    "disease_name_en": "Tuberculosis (TB)",
    "disease_name_bn": "যক্ষ্মা",
    "category": "infectious",
    "specialty": "pulmonology",
    "question": "What are common TB medication side effects?",
    "answer": "Orange urine/tears (from rifampicin — harmless), nausea, mild liver enzyme rise, joint pain, peripheral neuropathy (give B6/pyridoxine). Severe: jaundice, vision changes (ethambutol), severe rash. Report any to your doctor immediately."
  },
  {
    "disease_id": "tuberculosis",
    "disease_name_en": "Tuberculosis (TB)",
    "disease_name_bn": "যক্ষ্মা",
    "category": "infectious",
    "specialty": "pulmonology",
    "question": "Should my family get tested for TB?",
    "answer": "Yes, all household contacts should be screened — symptom check and chest X-ray; children may need Mantoux/TST. Children under 5 and HIV-positive contacts may receive isoniazid preventive therapy."
  },
  {
    "disease_id": "tuberculosis",
    "disease_name_en": "Tuberculosis (TB)",
    "disease_name_bn": "যক্ষ্মা",
    "category": "infectious",
    "specialty": "pulmonology",
    "question": "Can I get TB again after being cured?",
    "answer": "Yes, you can be re-infected, especially if exposed again or if immunity is compromised. Relapse from incompletely treated original infection is also possible. Continue good ventilation and avoid prolonged close contact with active TB patients."
  },
  {
    "disease_id": "cholera",
    "disease_name_en": "Cholera",
    "disease_name_bn": "কলেরা",
    "category": "infectious",
    "specialty": "general_medicine",
    "question": "What is Cholera?",
    "answer": "Acute diarrheal infection by Vibrio cholerae. Causes severe watery diarrhea, can be fatal within hours from dehydration. Bangladesh icddr,b is global leader in cholera research."
